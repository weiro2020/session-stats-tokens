#!/usr/bin/env python3
"""
Shows token statistics for the current Kilo/OpenCode/Codex session.
Usage: session-stats

Features:
- Reads from Kilo (SQLite), OpenCode (SQLite/JSON), Codex (JSONL), Hermes (SQLite), and Cursor CLI (hook JSONL).
- Auto-detects the most recently active session across all tools.
- Tracks input/output tokens per model.
- Calculates estimated costs based on hardcoded prices.
- Maintains a persistent history per session in SQLite (session_history.db).
"""

import json
import sqlite3
import datetime
from pathlib import Path
import sys

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR))
from stats_common import MODEL_COSTS, MODEL_ALIASES, normalize_model_name, calculate_cost, recalculate_historical_cost, get_codex_sessions, has_real_usage_codex, get_codex_session_stats, get_hermes_sessions, has_real_usage_hermes, get_hermes_session_stats, get_cursor_sessions, has_real_usage_cursor, get_cursor_session_stats, save_session, init_db, _parse_timestamp, _detect_source, DB_PATH

KILO_DB_PATH = Path.home() / ".local/share/kilo/kilo.db"
OPENCODE_DB_PATH = Path.home() / ".local/share/opencode/opencode.db"

def get_opencode_sessions():
    """Returns list of OpenCode sessions.
    
    Primero intenta leer de SQLite (v1.3.0+), sino fallback a JSON (v1.1.x).
    Returns list of dicts: {id, title, time_updated (ms), source: "sqlite"|"json"}
    """
    # Intentar SQLite primero (OpenCode 1.3.0+)
    if OPENCODE_DB_PATH.exists():
        try:
            conn = sqlite3.connect(str(OPENCODE_DB_PATH))
            cursor = conn.cursor()
            cursor.execute("SELECT id, title, time_updated FROM session ORDER BY time_updated DESC")
            sessions = [{"id": row[0], "title": row[1], "time_updated": row[2], "source": "sqlite"} 
                        for row in cursor.fetchall()]
            conn.close()
            if sessions:
                return sessions
        except Exception:
            pass
    
    # Fallback: JSON (OpenCode 1.1.x)
    opencode_dir = Path.home() / ".local/share/opencode/storage/message"
    if not opencode_dir.exists():
        return []
    sessions = []
    for d in opencode_dir.iterdir():
        if d.is_dir():
            sessions.append({"id": d.name, "title": "", "time_updated": int(d.stat().st_mtime * 1000), "source": "json", "path": d})
    sessions.sort(key=lambda x: x["time_updated"], reverse=True)
    return sessions

def get_kilo_sessions():
    """Returns list of Kilo sessions from SQLite database.
    
    Returns list of dicts: {id, title, time_updated (ms)}
    """
    if not KILO_DB_PATH.exists():
        return []
    try:
        conn = sqlite3.connect(str(KILO_DB_PATH))
        cursor = conn.cursor()
        cursor.execute("SELECT id, title, time_updated FROM session ORDER BY time_updated DESC")
        sessions = [{"id": row[0], "title": row[1], "time_updated": row[2]} for row in cursor.fetchall()]
        conn.close()
        return sessions
    except Exception:
        return []

def has_real_usage_json(session_path):
    """Check if a JSON session directory has real token usage."""
    for msg_file in session_path.glob("*.json"):
        try:
            with open(msg_file) as f:
                msg = json.load(f)
        except (json.JSONDecodeError, OSError):
            continue
        if msg.get("role") != "assistant":
            continue
        if msg.get("error"):
            continue
        tokens = msg.get("tokens", {}) or {}
        cache = tokens.get("cache", {}) if isinstance(tokens.get("cache", {}), dict) else {}
        total = (
            abs(tokens.get("input", 0))
            + abs(tokens.get("output", 0))
            + abs(tokens.get("reasoning", 0))
            + abs(cache.get("read", 0))
            + abs(cache.get("write", 0))
        )
        if total > 0:
            return True
    return False

def has_real_usage_sqlite(session_id, db_path=None):
    """Check if a SQLite session has real token usage."""
    if db_path is None:
        db_path = KILO_DB_PATH
    if not db_path.exists():
        return False
    try:
        conn = sqlite3.connect(str(db_path))
        cursor = conn.cursor()
        cursor.execute("SELECT data FROM message WHERE session_id = ?", (session_id,))
        for (data_str,) in cursor.fetchall():
            try:
                msg = json.loads(data_str)
                if msg.get("role") != "assistant":
                    continue
                tokens = msg.get("tokens", {}) or {}
                cache = tokens.get("cache", {}) or {}
                total = (
                    abs(tokens.get("input", 0))
                    + abs(tokens.get("output", 0))
                    + abs(tokens.get("reasoning", 0))
                    + abs(cache.get("read", 0))
                    + abs(cache.get("write", 0))
                )
                if total > 0:
                    conn.close()
                    return True
            except (json.JSONDecodeError, KeyError):
                continue
        conn.close()
        return False
    except Exception:
        return False

def get_current_session():
    """Finds the most recently active session from all sources (Kilo, OpenCode, Codex, Hermes).

    Returns a tuple: (source, session_ref, time_updated_ms)
    source: "kilo", "opencode_sqlite", "opencode_json", "codex", or "hermes"
    """
    candidates = []

    # Collect Kilo sessions with real usage
    for sess in get_kilo_sessions():
        if has_real_usage_sqlite(sess["id"]):
            candidates.append(("kilo", sess["id"], sess["time_updated"]))

    # Collect OpenCode sessions with real usage
    for sess in get_opencode_sessions():
        if sess["source"] == "sqlite":
            if has_real_usage_sqlite(sess["id"], OPENCODE_DB_PATH):
                candidates.append(("opencode_sqlite", sess["id"], sess["time_updated"]))
        else:
            if has_real_usage_json(sess["path"]):
                candidates.append(("opencode_json", sess["path"], sess["time_updated"]))

    # Collect Codex sessions with real usage
    for sess_file in get_codex_sessions():
        if has_real_usage_codex(sess_file):
            ts_ms = int(sess_file.stat().st_mtime * 1000)
            candidates.append(("codex", sess_file, ts_ms))

    # Collect Hermes sessions with real usage
    for sess in get_hermes_sessions():
        if has_real_usage_hermes(sess["id"]):
            ts_ms = int(sess["started_at"] * 1000) if sess.get("started_at") else 0
            candidates.append(("hermes", sess["id"], ts_ms, sess.get("ended_at")))

    if not candidates:
        return None

    # Priorizar sesión activa de Hermes (sin ended_at) sobre cualquier otra
    hermes_activa = [c for c in candidates if c[0] == "hermes" and not c[3]]
    if hermes_activa:
        best = max(hermes_activa, key=lambda x: x[2])
        return best[:3]

    # Return the one with the highest timestamp
    best = max(candidates, key=lambda x: x[2])
    return best[:3]

def get_session_stats_json(session_path):
    """Extracts statistics from an OpenCode JSON session."""
    stats = {
        "total_messages": 0,
        "by_model": {}
    }
    
    for msg_file in session_path.glob("*.json"):
        try:
            with open(msg_file) as f:
                msg = json.load(f)
            
            stats["total_messages"] += 1
            
            if msg.get("role") != "assistant":
                continue
            
            tokens = msg.get("tokens", {})
            if not tokens:
                continue
            if msg.get("error"):
                continue
            
            model = msg.get("modelID", "unknown")
            
            if model not in stats["by_model"]:
                stats["by_model"][model] = {
                    "requests": 0,
                    "input": 0,
                    "output": 0,
                    "reasoning": 0,
                    "cache": 0
                }

            stats["by_model"][model]["requests"] += 1
            cache_read = tokens.get("cache", {}).get("read", 0)
            stats["by_model"][model]["input"] += abs(tokens.get("input", 0))
            stats["by_model"][model]["cache"] += abs(cache_read)
            stats["by_model"][model]["output"] += abs(tokens.get("output", 0))
            stats["by_model"][model]["reasoning"] += abs(tokens.get("reasoning", 0))
            
        except (json.JSONDecodeError, KeyError):
            continue
    
    return stats

def get_session_stats_sqlite(session_id, db_path=None):
    """Extracts statistics from a SQLite session (Kilo or OpenCode)."""
    stats = {
        "total_messages": 0,
        "by_model": {},
        "session_title": "",
        "time_updated": 0
    }
    
    if db_path is None:
        db_path = KILO_DB_PATH
    if not db_path.exists():
        return stats
    
    try:
        conn = sqlite3.connect(str(db_path))
        cursor = conn.cursor()
        
        # Get session metadata
        cursor.execute("SELECT title, time_updated FROM session WHERE id = ?", (session_id,))
        row = cursor.fetchone()
        if row:
            stats["session_title"] = row[0] or ""
            stats["time_updated"] = row[1] or 0
        
        # Get messages
        cursor.execute("SELECT data FROM message WHERE session_id = ? ORDER BY time_created", (session_id,))
        for (data_str,) in cursor.fetchall():
            try:
                msg = json.loads(data_str)
            except json.JSONDecodeError:
                continue
            
            stats["total_messages"] += 1
            
            if msg.get("role") != "assistant":
                continue
            
            tokens = msg.get("tokens", {})
            if not tokens:
                continue
            
            model = msg.get("modelID", "unknown")
            
            if model not in stats["by_model"]:
                stats["by_model"][model] = {
                    "requests": 0,
                    "input": 0,
                    "output": 0,
                    "reasoning": 0,
                    "cache": 0
                }

            stats["by_model"][model]["requests"] += 1
            cache_read = (tokens.get("cache") or {}).get("read", 0)
            stats["by_model"][model]["input"] += abs(tokens.get("input", 0) or 0)
            stats["by_model"][model]["cache"] += abs(cache_read or 0)
            stats["by_model"][model]["output"] += abs(tokens.get("output", 0) or 0)
            stats["by_model"][model]["reasoning"] += abs(tokens.get("reasoning", 0) or 0)
        
        conn.close()
    except Exception:
        pass
    
    return stats

def format_number(n):
    """Formats large numbers with separators."""
    if n >= 1000000:
        return f"{n/1000000:.1f}M"
    elif n >= 1000:
        return f"{n/1000:.1f}K"
    return str(n)

def format_cost(cost):
    """Formats cost in dollars."""
    if cost >= 1:
        return f"${cost:.2f}"
    elif cost >= 0.01:
        return f"${cost:.4f}"
    return f"${cost:.6f}"

def merge_model_stats(by_model):
    """Combina estadisticas de modelos que son aliases."""
    merged = {}
    for model, data in by_model.items():
        normalized = normalize_model_name(model)
        if normalized not in merged:
            merged[normalized] = {"requests": 0, "input": 0, "output": 0, "reasoning": 0, "cache": 0}
        merged[normalized]["requests"] += data.get("requests", 0)
        merged[normalized]["input"] += data.get("input", 0)
        merged[normalized]["output"] += data.get("output", 0)
        merged[normalized]["reasoning"] += data.get("reasoning", 0)
        merged[normalized]["cache"] += data.get("cache", 0)
    return merged

def update_history(session_id, requests, input_tokens, output_tokens, cost, by_model, date=None):
    """Saves session to SQLite history (read-only from SQLite store)."""
    ts = _parse_timestamp(date) if date else int(datetime.datetime.now().timestamp())
    cache_tokens = sum(m.get("cache", 0) for m in by_model.values())
    reasoning_tokens = sum(m.get("reasoning", 0) for m in by_model.values())
    source = _detect_source(session_id)
    try:
        save_session(session_id, source, date or datetime.datetime.now().isoformat(),
                     ts, requests, input_tokens, output_tokens,
                     cache_tokens, reasoning_tokens, cost,
                     by_model, DB_PATH)
    except Exception:
        pass

def capture_all_sessions():
    """Captura y persiste TODAS las sesiones de todas las fuentes (Kilo, OpenCode, Codex, Hermes).

    Idempotente: ejecutarla multiples veces no duplica entradas.
    Retorna cantidad de sesiones nuevas capturadas.
    """
    existing_keys = set()
    if DB_PATH.exists():
        try:
            conn = sqlite3.connect(str(DB_PATH))
            rows = conn.execute("SELECT id FROM sessions").fetchall()
            existing_keys = {r[0] for r in rows}
            conn.close()
        except Exception:
            pass

    new_count = 0

    def _save_if_new(sid, entry):
        nonlocal new_count
        if sid in existing_keys or not entry:
            return
        existing_keys.add(sid)
        by_model = entry.get("by_model", {})
        if not by_model:
            return
        try:
            ts = _parse_timestamp(entry.get("date", ""))
            cache_tokens = sum(m.get("cache", 0) for m in by_model.values())
            reasoning_tokens = sum(m.get("reasoning", 0) for m in by_model.values())
            save_session(
                sid, _detect_source(sid),
                entry.get("date", ""), ts,
                entry.get("requests", 0),
                entry.get("input", 0),
                entry.get("output", 0),
                cache_tokens, reasoning_tokens,
                entry.get("cost", 0.0),
                by_model, DB_PATH
            )
            new_count += 1
        except Exception:
            pass

    # --- Kilo ---
    for sess in get_kilo_sessions():
        sid = sess["id"]
        if sid in existing_keys or not has_real_usage_sqlite(sid):
            continue
        stats = get_session_stats_sqlite(sid)
        if stats["by_model"]:
            _save_if_new(sid, _build_session_entry(stats["by_model"], sess["time_updated"] / 1000))

    # --- OpenCode SQLite ---
    for sess in get_opencode_sessions():
        if sess["source"] != "sqlite":
            continue
        sid = sess["id"]
        if sid in existing_keys or not has_real_usage_sqlite(sid, OPENCODE_DB_PATH):
            continue
        stats = get_session_stats_sqlite(sid, OPENCODE_DB_PATH)
        if stats["by_model"]:
            _save_if_new(sid, _build_session_entry(stats["by_model"], sess["time_updated"] / 1000))

    # --- Codex ---
    for sess_file in get_codex_sessions():
        if not has_real_usage_codex(sess_file):
            continue
        stats = get_codex_session_stats(sess_file)
        sid = "codex_" + (stats.get("session_id") or sess_file.stem)
        if sid in existing_keys:
            continue
        normalized = normalize_model_name(stats["model"])
        cost = calculate_cost(stats["model"], stats["input"], stats["output"], stats["cache"])
        _save_if_new(sid, {
            "date": stats.get("date", ""),
            "requests": stats["requests"],
            "input": stats["input"],
            "output": stats["output"],
            "cost": cost,
            "by_model": {normalized: {
                "requests": stats["requests"], "input": stats["input"],
                "output": stats["output"], "cache": stats["cache"], "cost": cost
            }}
        })

    # --- Hermes (siempre upsert: sesiones activas crecen) ---
    for sess in get_hermes_sessions():
        sid = sess["id"]
        by_model = sess.get("by_model", {})
        if not by_model:
            continue
        was_new = sid not in existing_keys
        try:
            by_model_with_cost = {}
            session_cost = 0
            for model, mdata in by_model.items():
                c = calculate_cost(model, mdata["input"], mdata["output"], mdata.get("cache", 0))
                session_cost += c
                by_model_with_cost[model] = {**mdata, "cost": c}
            cache_tokens = sum(m.get("cache", 0) for m in by_model_with_cost.values())
            save_session(
                sid, "hermes",
                sess.get("date", ""), sess.get("started_at", 0),
                sess.get("requests", 0),
                sess.get("input", 0),
                sess.get("output", 0),
                cache_tokens, sess.get("reasoning", 0),
                session_cost,
                by_model_with_cost, DB_PATH
            )
            if was_new:
                new_count += 1
            existing_keys.add(sid)
        except Exception:
            pass

    # --- Cursor CLI (siempre upsert: sesiones activas crecen) ---
    for sess in get_cursor_sessions():
        sid = f"cursor_{sess['id']}"
        by_model = sess.get("by_model", {})
        if not by_model:
            continue
        was_new = sid not in existing_keys
        try:
            by_model_with_cost = {}
            session_cost = 0
            for model, mdata in by_model.items():
                c = calculate_cost(model, mdata["input"], mdata["output"], mdata.get("cache", 0))
                session_cost += c
                by_model_with_cost[model] = {**mdata, "cost": c}
            cache_tokens = sum(m.get("cache", 0) for m in by_model_with_cost.values())
            save_session(
                sid, "cursor",
                sess.get("date", ""), sess.get("updated_at"),
                sess.get("requests", 0),
                sess.get("input", 0),
                sess.get("output", 0),
                cache_tokens, 0,
                session_cost,
                by_model_with_cost, DB_PATH
            )
            if was_new:
                new_count += 1
            existing_keys.add(sid)
        except Exception:
            pass

    return new_count


def _build_session_entry(by_model, timestamp):
    """Convierte estadisticas por modelo en una entrada de historial con costos."""
    merged = merge_model_stats(by_model)
    if not merged:
        return None
    session_cost = 0
    by_model_with_cost = {}
    for model, mdata in merged.items():
        c = calculate_cost(model, mdata["input"], mdata["output"], mdata["cache"])
        session_cost += c
        by_model_with_cost[model] = {**mdata, "cost": c}
    try:
        date = datetime.datetime.fromtimestamp(timestamp).isoformat()
    except Exception:
        date = ""
    return {
        "date": date,
        "requests": sum(m["requests"] for m in merged.values()),
        "input": sum(m["input"] for m in merged.values()),
        "output": sum(m["output"] for m in merged.values()),
        "cost": session_cost,
        "by_model": by_model_with_cost
    }


def main():
    if len(sys.argv) > 1 and sys.argv[1] == "--capture-all":
        new = capture_all_sessions()
        now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        if new > 0:
            print(f"[{now}] captured {new} new sessions")
        return

    session_info = get_current_session()
    if not session_info:
        print("No active session found")
        return
    
    source, session_ref, time_updated = session_info
    
    if source == "kilo":
        stats = get_session_stats_sqlite(session_ref)
        session_id = session_ref
        session_date = datetime.datetime.fromtimestamp(time_updated / 1000).isoformat()
    elif source == "opencode_sqlite":
        stats = get_session_stats_sqlite(session_ref, OPENCODE_DB_PATH)
        session_id = session_ref
        session_date = datetime.datetime.fromtimestamp(time_updated / 1000).isoformat()
    elif source == "codex":
        codex_stats = get_codex_session_stats(session_ref)
        session_id = codex_stats.get("session_id", session_ref.name)
        session_date = codex_stats.get("date", "")
        # Convertir a formato de stats compatible
        model = codex_stats["model"]
        stats = {
            "total_messages": codex_stats["requests"],
            "by_model": {
                model: {
                    "requests": codex_stats["requests"],
                    "input": codex_stats["input"],
                    "output": codex_stats["output"],
                    "reasoning": codex_stats["reasoning"],
                    "cache": codex_stats["cache"]
                }
            }
        }
    elif source == "hermes":
        hermes_stats = get_hermes_session_stats(session_ref)
        session_id = session_ref
        session_date = hermes_stats.get("date", "")
        stats = {
            "total_messages": hermes_stats.get("requests", 0),
            "by_model": hermes_stats.get("by_model", {}),
        }
    elif source == "cursor":
        cursor_stats = get_cursor_session_stats(session_ref)
        session_id = f"cursor_{session_ref}"
        session_date = cursor_stats.get("date", "")
        stats = {
            "total_messages": cursor_stats.get("requests", 0),
            "by_model": cursor_stats.get("by_model", {}),
            "session_title": cursor_stats.get("session_title", ""),
        }
    else:
        # opencode_json
        stats = get_session_stats_json(session_ref)
        session_id = session_ref.name
        session_date = datetime.datetime.fromtimestamp(session_ref.stat().st_mtime).isoformat()
    
    merged_by_model = merge_model_stats(stats["by_model"])
    
    total_requests = sum(m["requests"] for m in merged_by_model.values())
    total_input = sum(m["input"] for m in merged_by_model.values())
    total_output = sum(m["output"] for m in merged_by_model.values())
    total_cache = sum(m["cache"] for m in merged_by_model.values())
    
    total_session_cost = 0
    by_model_with_cost = {}
    for model, data in merged_by_model.items():
        model_cost = calculate_cost(model, data["input"], data["output"], data["cache"])
        total_session_cost += model_cost
        by_model_with_cost[model] = {
            "requests": data["requests"],
            "input": data["input"],
            "output": data["output"],
            "cache": data["cache"],
            "cost": model_cost
        }
    
    # Guardar sesión actual en historial (para tracking)
    update_history(
        session_id, total_requests, total_input, total_output, 
        total_session_cost, by_model_with_cost, date=session_date
    )
    
    # Recalcular TODO desde tokens (misma lógica que session-stats-history)
    hist = recalculate_historical_cost()
    total_historical_cost = hist["total_cost"]
    total_sessions = hist["total_sessions"]
    
    source_label = {"kilo": "Kilo", "opencode_sqlite": "OpenCode", "opencode_json": "OpenCode", "codex": "Codex", "hermes": "Hermes", "cursor": "Cursor"}.get(source, source)
    title_info = ""
    if source in ("kilo", "opencode_sqlite", "hermes", "cursor") and stats.get("session_title"):
        title_info = f" ({stats['session_title'][:50]})"
    print(f"📊 Current Session [{source_label}]{title_info}: {total_requests} req | In: {format_number(total_input)} | Out: {format_number(total_output)}")
    
    for model, data in merged_by_model.items():
        short_model = model.replace("antigravity-", "").replace("-thinking-high", "")
        if "/" in short_model:
            short_model = short_model.split("/", 1)[0]
        short_model = short_model.replace("-thinking", "")
        # Alias de visualización
        short_model = short_model.replace("grok-code-fast-1-optimized-free", "grok-code")
        short_model = short_model.replace("x-ai", "grok-4.1-fast")
        short_model = short_model.replace("deepseek-v4-flash", "ds-v4-flash")
        short_model = short_model.replace("deepseek-v4-pro", "ds-v4-pro")
        model_cost = calculate_cost(model, data["input"], data["output"], data["cache"])
        total_input = data["input"] + data["cache"]
        cache_info = f" (cache:{format_number(data['cache'])})" if data.get("cache", 0) > 0 else ""
        print(f"   └─ {short_model}: {data['requests']} req, in:{format_number(total_input)}{cache_info}, out:{format_number(data['output'])}, cost:{format_cost(model_cost)}")

    print(f"\n💰 Session Cost: {format_cost(total_session_cost)} - Historical Total ({total_sessions} sessions): {format_cost(total_historical_cost)}")

if __name__ == "__main__":
    main()
